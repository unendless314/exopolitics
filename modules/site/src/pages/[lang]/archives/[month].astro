---
import fs from "node:fs";
import path from "node:path";
import Base from "../../../layouts/Base.astro";
import Timeline from "../../../components/Timeline.astro";
import { useTranslations } from "../../../utils/i18n";
import { publishExportDir } from "../../../utils/paths";

import type { TimelinePost } from "../../../components/Timeline.astro";
import { validateCatalogItem } from "../../../utils/validation";
import type { CatalogItem } from "../../../utils/validation";

interface ArchiveEntry {
  archive_month: string;
  file_name: string;
  item_count: number;
  updated_at: string;
}

export function getStaticPaths() {
  const languages = ["zh", "en", "ja"];
  const paths = [];

  for (const lang of languages) {
    const archivesIndexFile = path.join(publishExportDir, lang, 'archives', 'index.json');
    if (fs.existsSync(archivesIndexFile)) {
      let archives: ArchiveEntry[] = [];
      try {
        archives = JSON.parse(fs.readFileSync(archivesIndexFile, "utf8"));
      } catch (err) {
        console.error(`Error parsing archives index for ${lang}:`, err);
        throw new Error(`Failed to parse archive manifest for ${lang}: ${err instanceof Error ? err.message : String(err)}`);
      }

      for (const archive of archives) {
        if (!archive.archive_month || typeof archive.archive_month !== "string") {
          throw new Error(`[Data Integrity Validation Failed] Archive index for ${lang} is missing a valid 'archive_month'`);
        }
        if (!archive.file_name || typeof archive.file_name !== "string") {
          throw new Error(`[Data Integrity Validation Failed] Archive index for ${lang} is missing a valid 'file_name'`);
        }
        paths.push({
          params: { lang, month: archive.archive_month },
          props: { fileName: archive.file_name },
        });
      }
    }
  }

  return paths;
}

const { lang = "zh", month } = Astro.params;
const { fileName } = Astro.props;
const t = useTranslations(lang);

// Read the archive list for this month
const archiveFile = path.join(publishExportDir, lang, 'archives', fileName);
let archiveItems: CatalogItem[] = [];
if (fs.existsSync(archiveFile)) {
  try {
    archiveItems = JSON.parse(fs.readFileSync(archiveFile, "utf8"));
  } catch (err) {
    console.error(`Error parsing archive file ${archiveFile}:`, err);
    throw new Error(`Failed to parse archive file ${fileName}: ${err instanceof Error ? err.message : String(err)}`);
  }
}

// Map simple catalog items to conform to TimelinePost and perform fail-fast validation
const mappedPosts: TimelinePost[] = archiveItems.map((item) => {
  const validated = validateCatalogItem(item, `archive file ${fileName} (${lang})`);
  return {
    slug: validated.slug,
    title: validated.display_title,
    publishDate: new Date(validated.source_published_at),
    description: validated.summary_short || validated.display_title,
  };
});

const pageTitle = `UAP Aggregator - ${t('archive.monthTitle', { month })}`;
const pageDesc = t('meta.archiveMonthDesc', { month });
---

<Base title={pageTitle} description={pageDesc} lang={lang}>
  <section class="mt-4">
    <div class="mb-8">
      <h1 class="font-serif text-3xl font-bold text-textColor mb-2">
        {t('archive.monthTitle', { month })}
      </h1>
      <p class="text-sm text-textColor/60 font-sans">
        {pageDesc} ({t('archive.totalItems', { count: archiveItems.length })})
      </p>
    </div>

    {archiveItems.length > 0 ? (
      <Timeline posts={mappedPosts} lang={lang} />
    ) : (
      <p class="text-textColor/60 font-sans">{t('archive.empty')}</p>
    )}
  </section>
</Base>
