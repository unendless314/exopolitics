---
import { getEntry } from "astro:content";
import PostLayout from "../../../layouts/Post.astro";
import translationMapRaw from "../../../content/_translation_map.json";

export function getStaticPaths() {
  const translationMap = translationMapRaw as Record<string, string[]>;
  const paths = [];
  for (const [slug, langs] of Object.entries(translationMap)) {
    for (const lang of langs) {
      paths.push({
        params: { lang, slug },
        props: { id: `generated/${lang}/${slug}` },
      });
    }
  }
  return paths;
}

interface Props {
  id: string;
}

const { id } = Astro.props as Props;
const { lang = "zh" } = Astro.params;

// Astro's generated content ID type is narrower than our runtime string path.
async function fetchPostEntry(postId: string) {
  return getEntry("posts", postId as any);
}

// Load post dynamically during rendering to prevent peak memory build-time retention
const post = await fetchPostEntry(id);
if (!post) {
  throw new Error(`[Data Integrity Validation Failed] Content collection post not found for ID: ${id}`);
}

const { Content } = await post.render();
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  publishDate={post.data.publishDate}
  canonicalUrl={post.data.canonicalUrl}
  disclosureNote={post.data.disclosureNote}
  authorMetadata={post.data.authorMetadata}
  content={post.body}
  lang={lang}
>
  <Content />
</PostLayout>
