---
import fs from "node:fs";
import path from "node:path";
import Base from "../../layouts/Base.astro";
import Timeline from "../../components/Timeline.astro";
import { useTranslations } from "../../utils/i18n";
import { publishExportDir } from "../../utils/paths";
import type { TimelinePost } from "../../components/Timeline.astro";
import { validateCatalogItem } from "../../utils/validation";
import type { CatalogItem } from "../../utils/validation";

export function getStaticPaths() {
  return [
    { params: { lang: "zh" } },
    { params: { lang: "en" } },
    { params: { lang: "ja" } },
  ];
}

const { lang = "zh" } = Astro.params;
const t = useTranslations(lang);

// 1. Directly read index.json from publish_export for metadata-only Ingestion
const indexFile = path.join(publishExportDir, lang, 'index.json');
let rawItems: CatalogItem[] = [];
if (fs.existsSync(indexFile)) {
  try {
    rawItems = JSON.parse(fs.readFileSync(indexFile, "utf8"));
  } catch (err) {
    console.error(`Error parsing index.json for ${lang}:`, err);
    throw new Error(`Failed to parse index.json for ${lang}: ${err instanceof Error ? err.message : String(err)}`);
  }
}

// 2. Limit to latest 300 posts
const displayItems = rawItems.slice(0, 300);

// 3. Fail-fast validation and mapping to TimelinePost interface
const displayPosts: TimelinePost[] = displayItems.map((item) => {
  const validated = validateCatalogItem(item, `index.json (${lang})`);
  return {
    slug: validated.slug,
    title: validated.display_title,
    publishDate: new Date(validated.source_published_at),
    description: validated.summary_short || validated.display_title,
  };
});

const pageTitle = `UAP Aggregator - ${t('nav.timeline')}`;
const pageDesc = t('meta.homeDesc');
---

<Base title={pageTitle} description={pageDesc} lang={lang}>
  <section class="mt-4">
    <div class="mb-8">
      <h1 class="font-serif text-3xl font-bold text-textColor mb-2">
        {t('nav.timeline')}
      </h1>
      <p class="text-sm text-textColor/60 font-sans">
        {pageDesc}
      </p>
    </div>
    
    <Timeline posts={displayPosts} lang={lang} />
  </section>
</Base>
