---
// Redirect to default language or browser language
---
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting...</title>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/zh/" />
    </noscript>
    <script is:inline>
      const langs = ['zh', 'en', 'ja'];
      const defaultLocale = 'zh';
      const browserLang = navigator.language.split('-')[0].toLowerCase();
      const targetLang = langs.includes(browserLang) ? browserLang : defaultLocale;
      window.location.href = `/${targetLang}/`;
    </script>
  </head>
  <body>
    <p>Redirecting...</p>
  </body>
</html>
