---
import { formatAbsoluteDateTime } from "../utils/i18n";
export interface TimelinePost {
  slug: string;
  title: string;
  publishDate: Date;
  description: string;
}

interface Props {
  posts: TimelinePost[];
  lang: string;
}

const { posts, lang } = Astro.props;
---

<div class="timeline mt-8">
  {posts.map((post) => {
    const postRoute = `/${lang}/posts/${post.slug}/`;

    return (
      <article class="post group">
        <div class="post-rail">
          <time class="post-date" datetime={post.publishDate.toISOString()}>
            {formatAbsoluteDateTime(post.publishDate.toISOString())}
          </time>
          <div class="post-dot" />
        </div>
        <div class="post-body">
          <h2 class="post-title">
            <a href={postRoute} class="focus:outline-none">
              {post.title}
            </a>
          </h2>
          <p class="post-preview">
            {post.description}
          </p>
        </div>
      </article>
    );
  })}
</div>
