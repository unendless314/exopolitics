---
import { getLocalePaths, localeProfiles } from "../utils/i18n";
import translationMapRaw from "../content/_translation_map.json";

// Safe casting for the imported JSON translation map
const translationMap = translationMapRaw as Record<string, string[]>;

interface Props {
  title: string;
  description: string;
  lang: string;
}

const { title, description } = Astro.props;
const currentUrl = Astro.url;
const pathname = currentUrl.pathname;

// Check if we are on a post detail page: /[lang]/posts/[slug]/
const postMatch = pathname.match(/^\/[a-z]{2}\/posts\/([^\/]+)/);
let availableLangs: string[] = ["zh", "en", "ja"];

if (postMatch) {
  const slug = postMatch[1];
  if (translationMap && translationMap[slug]) {
    availableLangs = translationMap[slug];
  }
}

// Generate alternate links for SEO, filtered by availability
const alternates = getLocalePaths(currentUrl)
  .filter(({ lang: altLang }) => availableLangs.includes(altLang))
  .map(({ lang: altLang, path }) => {
    const absoluteUrl = new URL(path, currentUrl.origin).href;
    return {
      lang: altLang,
      langTag: localeProfiles[altLang].langTag,
      href: absoluteUrl,
    };
  });

// Determine x-default (usually default locale 'zh' if available, otherwise first available, or fallback to root /zh/)
const defaultLocale = "zh";
const defaultAlt = alternates.find(alt => alt.lang === defaultLocale) || alternates[0];
const xDefaultHref = defaultAlt ? defaultAlt.href : new URL("/zh/", currentUrl.origin).href;

// Primary canonical URL
const canonicalHref = new URL(currentUrl.pathname, currentUrl.origin).href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

<!-- hreflang alternate links for SEO -->
{alternates.map(({ langTag, href }) => (
  <link rel="alternate" hreflang={langTag} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

<!-- Theme script to prevent flash of wrong theme -->
<script is:inline>
  const getTheme = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };
  document.documentElement.setAttribute('data-theme', getTheme());
</script>
