---
import { getLocalePaths, localeProfiles } from "../utils/i18n";
import translationMapRaw from "../content/_translation_map.json";

// Safe casting for the imported JSON translation map
const translationMap = translationMapRaw as Record<string, string[]>;

const currentUrl = Astro.url;
const pathname = currentUrl.pathname;

// Check if we are on a post detail page: /[lang]/posts/[slug]/
const postMatch = pathname.match(/^\/[a-z]{2}\/posts\/([^\/]+)/);
let availableLangs: string[] = ["zh", "en", "ja"];

if (postMatch) {
  const slug = postMatch[1];
  if (translationMap && translationMap[slug]) {
    availableLangs = translationMap[slug];
  }
}

const allPaths = getLocalePaths(currentUrl);
const paths = allPaths.filter(({ lang }) => availableLangs.includes(lang));
---

<div class="lang-selector">
  <select
    id="langSelect"
    onchange="window.location.href = this.value"
    class="bg-transparent text-textColor border border-hairline rounded px-2.5 py-1 font-sans text-sm cursor-pointer hover:border-accent focus:border-accent focus:outline-none transition-colors duration-200"
  >
    {paths.map(({ lang, path }) => (
      <option class="bg-bgColor text-textColor" value={path} selected={Astro.currentLocale === lang}>
        {localeProfiles[lang].label}
      </option>
    ))}
  </select>
</div>
