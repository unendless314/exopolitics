---
import Base from "./Base.astro";
import { formatAbsoluteDateTime, useTranslations } from "../utils/i18n";
import { calculateReadingTime } from "../utils/readingTime";

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  canonicalUrl?: string | null;
  disclosureNote?: string | null;
  authorMetadata?: {
    source_module?: string;
    writer_type?: string;
    editor?: string;
    upstream_updated_at?: string;
  } | null;
  content: string;
  lang: string;
}

const {
  title,
  description,
  publishDate,
  canonicalUrl,
  disclosureNote,
  authorMetadata,
  content,
  lang,
} = Astro.props;

const t = useTranslations(lang);
const readingTimeMins = calculateReadingTime(content);
---

<Base title={title} description={description} lang={lang}>
  <article class="mx-auto max-w-[64ch] mt-4 sm:mt-8">
    <!-- Header -->
    <header class="mb-8 border-b border-hairline pb-6">
      <h1 class="font-serif text-2xl sm:text-3.5xl font-bold leading-tight text-textColor mb-4 text-balance">
        {title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-sans text-textColor/60">
        <!-- Date -->
        <time datetime={publishDate.toISOString()} class="font-mono">
          {formatAbsoluteDateTime(publishDate.toISOString())}
        </time>
        
        <span class="text-faint">&bull;</span>
        
        <!-- Reading Time -->
        <span>
          {t('post.readingTime')}: {readingTimeMins} {t('post.minutes')}
        </span>
        
        {canonicalUrl && (
          <>
            <span class="text-faint">&bull;</span>
            <a
              href={canonicalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline font-medium"
            >
              {t('post.originalSource')} &rarr;
            </a>
          </>
        )}
      </div>
    </header>

    <!-- Body Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Metadata & Disclosures Card -->
    {(disclosureNote || authorMetadata) && (
      <div class="mt-12 rounded-lg border border-hairline bg-paper p-5 sm:p-6 transition-all duration-300">
        <h3 class="font-serif text-base font-semibold text-textColor mb-3 border-b border-hairline pb-2">
          {t('post.disclosure')}
        </h3>
        
        {disclosureNote && (
          <p class="text-sm text-textColor/80 leading-relaxed mb-4">
            {disclosureNote}
          </p>
        )}
        
        {authorMetadata && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-sans text-textColor/60">
            {authorMetadata.source_module && (
              <div>
                <span class="font-medium text-textColor/80">{t('post.sourceModule')}:</span>{" "}
                <code class="px-1.5 py-0.5 rounded bg-accent-soft text-[11px]">{authorMetadata.source_module}</code>
              </div>
            )}
            {authorMetadata.writer_type && (
              <div>
                <span class="font-medium text-textColor/80">{t('post.writerType')}:</span>{" "}
                <span class="font-semibold text-textColor/80">{authorMetadata.writer_type}</span>
              </div>
            )}
            {authorMetadata.editor && (
              <div>
                <span class="font-medium text-textColor/80">{t('post.editor')}:</span>{" "}
                <span class="font-semibold text-textColor/80">{authorMetadata.editor}</span>
              </div>
            )}
            {authorMetadata.upstream_updated_at && (
              <div class="sm:col-span-2">
                <span class="font-medium text-textColor/80">Updated Upstream:</span>{" "}
                <time datetime={authorMetadata.upstream_updated_at} class="font-mono text-textColor/80">
                  {formatAbsoluteDateTime(authorMetadata.upstream_updated_at)}
                </time>
              </div>
            )}
          </div>
        )}
      </div>
    )}
  </article>
</Base>
